// Prisma generator
generator client {
  provider = "prisma-client-js"
}

// Database connection
datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ===============================
// MEMBER TABLE
// ===============================
model Member {
  // Primary Key
  id        Int      @id @default(autoincrement())


  memberName      String
  memberEmail     String   @unique
  memberAge       Int
  memberParentId  Int?

  // Self-relation for parent-child hierarchy
  parent    Member?  @relation("MemberParent", fields: [memberParentId], references: [id], onDelete: SetNull)
  children  Member[] @relation("MemberParent")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One-to-Many relation
  marks     Mark[]

  @@index([memberParentId])
}

// ===============================
// MARK TABLE
// ===============================
model Mark {
  id        Int     @id @default(autoincrement())
  subject   String
  score     Int
  
  // Foreign key
  memberId  Int

  // Relation with Member
  member    Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
}
